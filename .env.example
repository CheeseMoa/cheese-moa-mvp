# 로컬 개발용 env 예시 — `cp .env.example .env.development` (이 파일 자체는 vite가 읽지 않는다)
# MSW 목 API 활성화 — FE가 BE 없이 목 데이터로 개발 (목이 실 BE 계약을 구현 — CHMO-195)
# 실 BE 연동 확인 시 false로 — /api/v1 요청이 vite 프록시를 타고 VITE_API_ORIGIN으로 전달된다
VITE_ENABLE_MSW=true

# 실 BE 오리진(vite dev 프록시 대상) — 미설정 시 http://3.35.177.22 (vite.config.ts 기본값)
# VITE_API_ORIGIN=http://3.35.177.22
